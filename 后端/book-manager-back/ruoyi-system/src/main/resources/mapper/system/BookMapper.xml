<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BookMapper">

    <resultMap type="Book" id="BookResult">
        <id     property="bookId"        column="book_id"        />
        <result property="bookName"      column="book_name"      />
        <result property="isbn"          column="isbn"           />
        <result property="type"          column="type"           />
        <result property="author"        column="author"         />
        <result property="press"         column="press"          />
        <result property="publishDate"   column="publish_date"   />
        <result property="price"         column="price"          />
        <result property="stockCount"    column="stock_count"    />
        <result property="shelfLocation" column="shelf_location" />
        <result property="coverImage"    column="cover_image"    />
        <result property="description"   column="description"    />
        <result property="status"        column="status"         />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>

    <sql id="selectBookVo">
        select b.book_id, b.book_name, b.isbn, b.type, b.author, b.press, b.publish_date, b.price, b.stock_count, b.shelf_location, b.cover_image, b.description, b.status, b.create_by, b.create_time, b.update_by, b.update_time, b.remark
        from tb_book b
    </sql>

    <select id="selectBookList" parameterType="Book" resultMap="BookResult">
        select b.book_id, b.book_name, b.isbn, b.type, b.author, b.press, b.publish_date, b.price, b.stock_count, b.shelf_location, b.cover_image, b.description, b.status, b.create_by, b.create_time, b.update_by, b.update_time, b.remark
        from tb_book b
        <where>
            <if test="bookName != null and bookName != ''">
                AND b.book_name like concat('%', #{bookName}, '%')
            </if>
            <if test="isbn != null and isbn != ''">
                AND b.isbn like concat('%', #{isbn}, '%')
            </if>
            <if test="type != null and type != ''">
                AND b.type = #{type}
            </if>
            <if test="author != null and author != ''">
                AND b.author like concat('%', #{author}, '%')
            </if>
            <if test="press != null and press != ''">
                AND b.press like concat('%', #{press}, '%')
            </if>
            <if test="status != null and status != ''">
                AND b.status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                AND b.create_time &gt;= #{params.beginTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                AND b.create_time &lt;= #{params.endTime}
            </if>
        </where>
    </select>

    <select id="selectBookById" parameterType="Long" resultMap="BookResult">
        <include refid="selectBookVo"/>
        where b.book_id = #{bookId}
    </select>

    <select id="checkBookNameUnique" parameterType="String" resultMap="BookResult">
        select book_id, book_name from tb_book where book_name = #{bookName} limit 1
    </select>

    <insert id="insertBook" parameterType="Book" useGeneratedKeys="true" keyProperty="bookId">
        insert into tb_book(
            <if test="bookName != null and bookName != ''">book_name,</if>
            <if test="isbn != null and isbn != ''">isbn,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="author != null and author != ''">author,</if>
            <if test="press != null and press != ''">press,</if>
            <if test="publishDate != null">publish_date,</if>
            <if test="price != null">price,</if>
            <if test="stockCount != null">stock_count,</if>
            <if test="shelfLocation != null and shelfLocation != ''">shelf_location,</if>
            <if test="coverImage != null and coverImage != ''">cover_image,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="bookName != null and bookName != ''">#{bookName},</if>
            <if test="isbn != null and isbn != ''">#{isbn},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="author != null and author != ''">#{author},</if>
            <if test="press != null and press != ''">#{press},</if>
            <if test="publishDate != null">#{publishDate},</if>
            <if test="price != null">#{price},</if>
            <if test="stockCount != null">#{stockCount},</if>
            <if test="shelfLocation != null and shelfLocation != ''">#{shelfLocation},</if>
            <if test="coverImage != null and coverImage != ''">#{coverImage},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateBook" parameterType="Book">
        update tb_book
        <set>
            <if test="bookName != null and bookName != ''">book_name = #{bookName},</if>
            <if test="isbn != null">isbn = #{isbn},</if>
            <if test="type != null and type != ''">type = #{type},</if>
            <if test="author != null">author = #{author},</if>
            <if test="press != null">press = #{press},</if>
            <if test="publishDate != null">publish_date = #{publishDate},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stockCount != null">stock_count = #{stockCount},</if>
            <if test="shelfLocation != null">shelf_location = #{shelfLocation},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where book_id = #{bookId}
    </update>

    <delete id="deleteBookById" parameterType="Long">
        delete from tb_book where book_id = #{bookId}
    </delete>

    <delete id="deleteBookByIds" parameterType="Long">
        delete from tb_book where book_id in
        <foreach collection="array" item="bookId" open="(" separator="," close=")">
            #{bookId}
        </foreach>
    </delete>

    <select id="selectBookForUpdate" parameterType="Integer" resultMap="BookResult">
        <include refid="selectBookVo"/>
        where b.book_id = #{bookId}
        for update
    </select>

    <update id="decrementStock" parameterType="Integer">
        update tb_book
        set stock_count = stock_count - 1
        where book_id = #{bookId}
          and stock_count > 0
    </update>

    <update id="incrementStock" parameterType="Integer">
        update tb_book
        set stock_count = stock_count + 1
        where book_id = #{bookId}
    </update>

</mapper>
