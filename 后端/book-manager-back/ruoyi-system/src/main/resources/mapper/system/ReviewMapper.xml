<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.ReviewMapper">

    <resultMap type="BookReview" id="ReviewResult">
        <id     property="reviewId"   column="review_id"    />
        <result property="bookId"     column="book_id"      />
        <result property="readerId"   column="reader_id"    />
        <result property="rating"     column="rating"       />
        <result property="content"    column="content"      />
        <result property="status"     column="status"       />
        <result property="createBy"   column="create_by"    />
        <result property="createTime" column="create_time"  />
        <result property="updateBy"   column="update_by"    />
        <result property="updateTime" column="update_time"  />
        <result property="remark"     column="remark"       />
        <result property="bookName"   column="book_name"    />
        <result property="readerName" column="reader_name"  />
    </resultMap>

    <sql id="selectReviewVo">
        select rv.review_id, rv.book_id, rv.reader_id, rv.rating, rv.content, rv.status,
               rv.create_by, rv.create_time, rv.update_by, rv.update_time, rv.remark,
               b.book_name, rd.name as reader_name
        from tb_book_review rv
        left join tb_book b on rv.book_id = b.book_id
        left join tb_reader rd on rv.reader_id = rd.reader_id
    </sql>

    <select id="selectReviewList" parameterType="BookReview" resultMap="ReviewResult">
        <include refid="selectReviewVo"/>
        <where>
            <if test="bookId != null and bookId != 0">
                AND rv.book_id = #{bookId}
            </if>
            <if test="readerId != null and readerId != 0">
                AND rv.reader_id = #{readerId}
            </if>
            <if test="rating != null">
                AND rv.rating = #{rating}
            </if>
            <if test="status != null and status != ''">
                AND rv.status = #{status}
            </if>
            <if test="bookName != null and bookName != ''">
                AND b.book_name like concat('%', #{bookName}, '%')
            </if>
        </where>
        order by rv.create_time desc
    </select>

    <select id="selectReviewById" parameterType="Long" resultMap="ReviewResult">
        <include refid="selectReviewVo"/>
        where rv.review_id = #{reviewId}
    </select>

    <select id="selectReviewByBookId" parameterType="Long" resultMap="ReviewResult">
        <include refid="selectReviewVo"/>
        where rv.book_id = #{bookId}
          and rv.status = '1'
        order by rv.create_time desc
    </select>

    <select id="selectAvgRatingByBookId" parameterType="Long" resultType="Double">
        select coalesce(round(avg(rating), 1), 0)
        from tb_book_review
        where book_id = #{bookId}
          and status = '1'
    </select>

    <select id="selectRatingCountByBookId" parameterType="Long" resultType="Integer">
        select count(*)
        from tb_book_review
        where book_id = #{bookId}
          and status = '1'
    </select>

    <insert id="insertReview" parameterType="BookReview" useGeneratedKeys="true" keyProperty="reviewId">
        insert into tb_book_review(
            <if test="bookId != null">book_id,</if>
            <if test="readerId != null">reader_id,</if>
            <if test="rating != null">rating,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="bookId != null">#{bookId},</if>
            <if test="readerId != null">#{readerId},</if>
            <if test="rating != null">#{rating},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateReview" parameterType="BookReview">
        update tb_book_review
        <set>
            <if test="bookId != null">book_id = #{bookId},</if>
            <if test="readerId != null">reader_id = #{readerId},</if>
            <if test="rating != null">rating = #{rating},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where review_id = #{reviewId}
    </update>

    <delete id="deleteReviewById" parameterType="Long">
        delete from tb_book_review where review_id = #{reviewId}
    </delete>

    <delete id="deleteReviewByIds" parameterType="Long">
        delete from tb_book_review where review_id in
        <foreach collection="array" item="reviewId" open="(" separator="," close=")">
            #{reviewId}
        </foreach>
    </delete>

</mapper>
