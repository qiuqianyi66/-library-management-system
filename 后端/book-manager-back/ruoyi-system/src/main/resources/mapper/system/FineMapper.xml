<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.FineMapper">

    <resultMap type="FineRecord" id="FineRecordResult">
        <id     property="fineId"     column="fine_id"      />
        <result property="borrowId"   column="borrow_id"    />
        <result property="readerId"   column="reader_id"    />
        <result property="amount"     column="amount"       />
        <result property="status"     column="status"       />
        <result property="payMethod"  column="pay_method"   />
        <result property="payTime"    column="pay_time"     />
        <result property="createBy"   column="create_by"    />
        <result property="createTime" column="create_time"  />
        <result property="updateBy"   column="update_by"    />
        <result property="updateTime" column="update_time"  />
        <result property="readerName" column="reader_name" />
        <result property="remark"     column="remark"       />
    </resultMap>

    <sql id="selectFineVo">
        select f.fine_id, f.borrow_id, f.reader_id, f.amount, f.status, f.pay_method, f.pay_time, f.create_by, f.create_time, f.update_by, f.update_time, f.remark,
               r.name as reader_name
        from tb_fine_record f
        left join tb_reader r on f.reader_id = r.reader_id
    </sql>

    <select id="selectFineList" parameterType="FineRecord" resultMap="FineRecordResult">
        <include refid="selectFineVo"/>
        <where>
            <if test="borrowId != null and borrowId != 0">
                AND f.borrow_id = #{borrowId}
            </if>
            <if test="readerId != null and readerId != 0">
                AND f.reader_id = #{readerId}
            </if>
            <if test="status != null and status != ''">
                AND f.status = #{status}
            </if>
            <if test="readerName != null and readerName != ''">
                AND r.name like concat('%', #{readerName}, '%')
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND f.create_time &gt;= #{params.beginTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND f.create_time &lt;= #{params.endTime}
            </if>
        </where>
    </select>

    <select id="selectFineById" parameterType="Long" resultMap="FineRecordResult">
        <include refid="selectFineVo"/>
        where f.fine_id = #{fineId}
    </select>

    <!-- 仪表盘：本月罚款收入 -->
    <select id="selectMonthlyFineIncome" resultType="java.math.BigDecimal">
        select coalesce(sum(amount), 0)
        from tb_fine_record
        where status = '1'
          and pay_time >= date_format(now(), '%Y-%m-01')
    </select>

    <select id="selectFineByReaderId" parameterType="Integer" resultMap="FineRecordResult">
        <include refid="selectFineVo"/>
        where f.reader_id = #{readerId}
        order by f.create_time desc
    </select>

    <insert id="insertFine" parameterType="FineRecord" useGeneratedKeys="true" keyProperty="fineId">
        insert into tb_fine_record(
            <if test="borrowId != null">borrow_id,</if>
            <if test="readerId != null">reader_id,</if>
            <if test="amount != null">amount,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="payMethod != null and payMethod != ''">pay_method,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="borrowId != null">#{borrowId},</if>
            <if test="readerId != null">#{readerId},</if>
            <if test="amount != null">#{amount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="payMethod != null and payMethod != ''">#{payMethod},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateFine" parameterType="FineRecord">
        update tb_fine_record
        <set>
            <if test="borrowId != null">borrow_id = #{borrowId},</if>
            <if test="readerId != null">reader_id = #{readerId},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="payMethod != null and payMethod != ''">pay_method = #{payMethod},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where fine_id = #{fineId}
    </update>

</mapper>
